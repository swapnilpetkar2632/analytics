   "source": [
    "num= int(input(\"Enter a number: \"))\n",
    "temp=num\n",
    "rev =0\n",
    "while num>0:\n",
    "    digit = num%10\n",
    "    rev = rev*10 + digit\n",
    "    num = num // 10\n",
    "\n",
    "if  rev == temp:\n",
    "    print(\"it is polidrom\")\n",
    "else:\n",
    "    print(\"it is not polidrom\")\n"
   ]
